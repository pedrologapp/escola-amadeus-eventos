# Copie este arquivo para .env.local e preencha os valores reais
# .env.local nunca vai pro Git

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# n8n webhook (inscrições → Asaas)
N8N_WEBHOOK_URL=https://webhook.example.com/webhook/eventos

# n8n webhook de notificação (Asaas confirma + dispara QR/WhatsApp;
# também usado em vendas em dinheiro)
N8N_NOTIFICACAO_URL=https://webhook.example.com/webhook/eventospagamentos

# Segredo compartilhado pro callback /api/inscricoes/confirmar
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_CONFIRM_SECRET=mude-isto-por-um-secret-aleatorio

# Anthropic API (extração de avisos com IA — Claude Sonnet 4.6)
# Crie em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Senha para ações sensíveis no admin (editar/excluir/duplicar evento)
# Se não definida, usa um padrão no código.
ADMIN_ACTION_PASSWORD=troque-esta-senha

# URLs base
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://admin.localhost:3000
